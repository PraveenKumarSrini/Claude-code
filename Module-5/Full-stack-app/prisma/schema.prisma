generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Post {
  id        Int       @id @default(autoincrement())
  title     String
  body      String
  createdAt DateTime  @default(now())
  comments  Comment[]
}

model Comment {
  id         Int      @id @default(autoincrement())
  authorName String
  body       String
  createdAt  DateTime @default(now())
  postId     Int
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}
