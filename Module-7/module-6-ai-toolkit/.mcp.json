{
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "."
            ]
        },
        "github": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "env": {
                "GITHUB_TOKEN": ""
            }
        },
        "env-config": {
            "command": "npx",
            "args": [
                "ts-node",
                "src/mcp-env-config.ts"
            ]
        }
    }
}